<launch>
  <arg name="launch_package" default="kassow_kord_bringup" description="The ROS package where we find the launch files."/>
  <arg name="start_rviz" default="true" description="Launch RViz visualization?"/>
  <arg name="default_planning_pipeline" default="ompl"/>

  <include file="$(find-pkg-share $(var launch_package))/launch/kassow_kord_moveit.launch.xml">
    <arg name="default_planning_pipeline" value="$(var default_planning_pipeline)"/>
    <arg name="start_rviz" value="$(var start_rviz)"/>
  </include>

  <include file="$(find-pkg-share $(var launch_package))/launch/kassow_kord_bringup.launch.xml">
    <arg name="hardware" value="mock"/>
    <arg name="start_rviz" value="false"/>
  </include>
</launch>
