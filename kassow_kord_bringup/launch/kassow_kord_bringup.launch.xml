<launch>
  <arg name="configuration_package" default="kassow_kord_bringup" description="The ROS package where we find the configuration files."/>
  <arg name="hardware" default="mock" description="Choose the type of hardware to start. Options: mock, kr810.">
    <choice value="mock"/>
    <choice value="kr810"/>
  </arg>
  <arg name="ip_address" default="10.28.28.11" description="IP address of the robot."/>
  <arg name="port" default="7582" description="Port of the robot."/>
  <arg name="session_id" default="1" description="Session ID of the robot."/>

  <arg name="start_rviz" default="true" description="Launch RViz visualization?"/>
  <arg name="robot_controller" default="joint_trajectory_controller" description="Robot controller to start.">
    <choice value="joint_trajectory_controller"/>
  </arg>

  <let name="prefix" value=""/>
  <let name="controllers_file_path" value="$(find-pkg-share $(var configuration_package))/config/kassow_kord_controllers.yaml"/>

  <include file="$(find-pkg-share $(var configuration_package))/launch/kassow_kord_description.launch.xml">
    <arg name="description_package" value="$(var configuration_package)"/>
    <arg name="prefix" value="$(var prefix)"/>
    <arg name="hardware" value="$(var hardware)"/>
    <arg name="ip_address" value="$(var ip_address)"/>
    <arg name="port" value="$(var port)"/>
    <arg name="session_id" value="$(var session_id)"/>
  </include>

  <node pkg="controller_manager" exec="ros2_control_node" name="b_controlled_box_cm" output="both">
    <param name="update_rate" value="250"/>
    <param from="$(var controllers_file_path)"/>
  </node>

  <node pkg="controller_manager" exec="spawner" name="joint_state_broadcaster_spawner" output="screen" args="joint_state_broadcaster -c /b_controlled_box_cm"/>
  <node pkg="controller_manager" exec="spawner" name="robot_controller_spawner" output="screen" args="$(var robot_controller) -c /b_controlled_box_cm"/>

  <node if="$(var start_rviz)" pkg="rviz2" exec="rviz2" name="rviz2" output="both" args="-d $(find-pkg-share $(var configuration_package))/config/kassow_kord.rviz --ros-args --log-level fatal"/>

</launch>
